---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'LedgerLab — 회계사가 직접 만드는 실사·감사 자동화',
  description = '현직 CPA가 실사(DD)·감사·밸류에이션을 자동화 엔진으로 풀어가는 과정의 기록.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // 끝 슬래시 보장 (서브경로 대응)
const nav = [
  { href: `${base}#about`, label: '소개' },
  { href: `${base}blog`, label: '글' },
  { href: `${base}#build`, label: '만드는 것' },
  { href: `${base}#contact`, label: '연락' },
];
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <div class="wrap nav">
      <a class="brand" href={base}>Ledger<span>Lab</span></a>
      <nav class="nav-links">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <div class="wrap">
      <div class="foot-row">
        <div>© 2026 <b>LedgerLab</b> · 글: M.K.</div>
        <div class="foot-links">
          <a href={`${base}blog`}>글</a>
          <a href={`${base}#contact`}>연락</a>
        </div>
      </div>
      <p class="disclaimer">
        본 사이트의 글과 자료는 일반적 정보 제공을 위한 것이며 특정 거래에 대한
        회계·세무·법률 자문이 아닙니다. 게재된 모든 사례는 익명화·일반화되었으며
        실제 고객·거래 정보를 포함하지 않습니다. 실제 의사결정은 반드시 자격 있는
        전문가의 개별 검토를 거쳐야 합니다.
      </p>
    </div>
  </footer>
</body>
</html>

<style is:global>
  :root{
    --bg:#ffffff; --bg2:#f7f8fa; --card:#ffffff; --line:#e6e9ef;
    --ink:#1a2233; --muted:#586176; --faint:#99a2b3;
    --navy:#1a2233; --navy-soft:#eef1f6;
    --accent:#c9a227; --accent-ink:#8a6d16; --accent-soft:#f6efda;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Malgun Gothic',sans-serif;
    background:var(--bg);color:var(--ink);line-height:1.7;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:860px;margin:0 auto;padding:0 24px}

  /* nav */
  header{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.82);
    backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
  .nav{display:flex;align-items:center;justify-content:space-between;height:64px}
  .brand{font-weight:700;font-size:18px;letter-spacing:.3px}
  .brand span{color:var(--accent-ink)}
  .nav-links{display:flex;gap:26px;font-size:14px;color:var(--muted)}
  .nav-links a:hover{color:var(--ink)}
  @media(max-width:560px){.nav-links{gap:16px;font-size:13px}}

  /* sections */
  section{padding:60px 0;border-top:1px solid var(--line)}
  .sec-label{font-size:12px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;
    color:var(--faint);margin-bottom:18px}
  h2{font-size:26px;font-weight:700;letter-spacing:-.3px;margin-bottom:16px}
  .lead{color:var(--muted);font-size:16px;max-width:640px}

  /* buttons */
  .btn{display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:600;
    padding:12px 20px;border-radius:10px;transition:.18s}
  .btn-primary{background:var(--navy);color:#fff}
  .btn-primary:hover{filter:brightness(1.18);transform:translateY(-1px)}
  .btn-ghost{border:1px solid var(--line);color:var(--ink)}
  .btn-ghost:hover{border-color:var(--accent);color:var(--accent-ink)}

  /* footer */
  footer{border-top:1px solid var(--line);padding:40px 0;color:var(--faint);font-size:13px;margin-top:20px}
  .foot-row{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
  .foot-row b{color:var(--ink)}
  .foot-links{display:flex;gap:18px}
  .foot-links a:hover{color:var(--ink)}
  .disclaimer{margin-top:18px;font-size:11.5px;color:#a0a7b2;line-height:1.6;max-width:680px}
</style>
