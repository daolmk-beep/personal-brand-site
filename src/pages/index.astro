---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// 최근 글 5편 (draft 제외, 날짜 내림차순)
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<Base>
  <!-- HERO -->
  <div class="wrap">
    <section class="hero">
      <span class="eyebrow">AI · 자동화 융합 CPA</span>
      <h1>회계사가 직접 만드는<br><b>실사·밸류에이션·IB 자동화</b>의 기록.</h1>
      <p>재무·세무실사부터 밸류에이션, 그리고 산업분석·Porter 5 Forces·IM 덱까지 —
         손이 아니라 <b>엔진</b>으로 푼다. 증거에서 출발하고, 골든값으로 검증하며,
         결론은 사람이 책임진다. 그 과정에서 배운 것을 여기에 적습니다.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={`${base}blog`}>글 읽기 →</a>
        <a class="btn btn-ghost" href="#about">무엇을 하는 사람인가</a>
      </div>
    </section>
  </div>

  <!-- ABOUT -->
  <div class="wrap">
    <section id="about">
      <div class="sec-label">About</div>
      <h2>손으로 하던 실사를, 검증 가능한 파이프라인으로.</h2>
      <p class="lead">현직 CPA로 M&amp;A·투자 실사와 감사를 합니다. 동시에 그 업무를
        반복 가능하고 추적 가능한 자동화 엔진으로 다시 짓고 있습니다.
        빠른 AI 초안과, 그것을 검증하는 회계사의 책임 — 두 가지를 한 자리에 둡니다.</p>

      <div class="pillars">
        <div class="pillar">
          <div class="ic">🧱</div>
          <h3>증거 우선 (Evidence-First)</h3>
          <p>결론보다 절차가 먼저. 모든 발견사항은 해시로 봉인된 증거로 역추적됩니다.</p>
        </div>
        <div class="pillar">
          <div class="ic">🎯</div>
          <h3>골든값 검증</h3>
          <p>DCF·WACC를 0.000% 오차로 재현할 때까지 모듈을 승격하지 않습니다.</p>
        </div>
        <div class="pillar">
          <div class="ic">⚖️</div>
          <h3>책임의 경계</h3>
          <p>AI는 초안·요약·플래그까지. 최종 판단과 의견 표명은 사람(CPA)이 합니다.</p>
        </div>
      </div>
    </section>
  </div>

  <!-- WRITING -->
  <div class="wrap">
    <section id="writing">
      <div class="sec-label">Writing</div>
      <h2>최근 글</h2>
      <p class="lead">실사·감사·밸류에이션을 자동화하며 마주친 문제와 방법론.
        구체적 딜 정보는 담지 않습니다.</p>

      <div class="posts">
        {posts.map((post) => (
          <a class="post" href={`${base}blog/${post.slug}`}>
            <div class="post-date">{fmt(post.data.date)}</div>
            <div class="post-body">
              {post.data.tag && <span class="post-tag">{post.data.tag}</span>}
              <div class="post-title">{post.data.title}</div>
              {post.data.excerpt && <p class="post-excerpt">{post.data.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>

      <div style="margin-top:24px">
        <a class="btn btn-ghost" href={`${base}blog`}>글 전체 보기 →</a>
      </div>
    </section>
  </div>

  <!-- BUILD -->
  <div class="wrap">
    <section id="build">
      <div class="sec-label">What I Build</div>
      <h2>직접 만든 것들</h2>
      <p class="lead">업무를 풀기 위해 만든 분석 엔진과 자동화 파이프라인. 모두 셀프테스트로 게이팅됩니다.</p>

      <div class="build">
        <div class="build-group">
          <div class="build-group-label">실사 · 감사 · 밸류에이션</div>
          <div class="build-grid">
            <div class="chip"><span class="dot">◆</span><div><b>dd-analytics 엔진</b> — 설비 노후도·노동생산성·NWC/CCC·연차충당·비교재무제표 모듈</div></div>
            <div class="chip"><span class="dot">◆</span><div><b>밸류에이션 엔진</b> — WACC·DCF·NAV·Comps·풋볼필드, 수식 연동 엑셀 익스포트</div></div>
            <div class="chip"><span class="dot">◆</span><div><b>FDD 보고서 자동화</b> — 증거 해시로깅부터 PPTX 초안까지의 파이프라인</div></div>
            <div class="chip"><span class="dot">◆</span><div><b>부정탐지 모듈</b> — 결산분개·이상거래 탐지와 자기개선 피드백 루프</div></div>
          </div>
        </div>

        <div class="build-group">
          <div class="build-group-label">IB 업무 자동화</div>
          <div class="build-grid">
            <div class="chip"><span class="dot">◆</span><div><b>산업분석 엔진</b> — 시장 규모·성장률·밸류체인·경쟁구도 자동 리서치 &amp; 구조화</div></div>
            <div class="chip"><span class="dot">◆</span><div><b>Porter 5 Forces 분석</b> — 5대 경쟁요인 정형화·근거 매핑·산업 매력도 스코어링</div></div>
            <div class="chip"><span class="dot">◆</span><div><b>IM 덱 빌더 (맥킨지 수준)</b> — 스토리라인·차트·페이지 그리드까지 컨설팅급 PPTX 초안</div></div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- CONTACT -->
  <div class="wrap">
    <section id="contact">
      <div class="contact-box">
        <h2>같이 이야기 나눌까요?</h2>
        <p>실사·감사 자동화, 밸류에이션 모델링, 또는 글에 대한 어떤 이야기든.</p>
        <a class="btn btn-primary" href="mailto:daolmk@gmail.com">이메일 보내기</a>
      </div>
    </section>
  </div>
</Base>

<style>
  .hero{padding:96px 0 72px;border-top:none}
  .eyebrow{display:inline-block;font-size:12px;font-weight:600;letter-spacing:1.5px;
    text-transform:uppercase;color:var(--accent-ink);background:var(--accent-soft);
    padding:6px 12px;border-radius:999px;margin-bottom:24px}
  .hero h1{font-size:44px;line-height:1.25;font-weight:700;letter-spacing:-.5px;margin-bottom:22px}
  .hero h1 b{color:var(--accent-ink);font-weight:700}
  .hero p{font-size:18px;color:var(--muted);max-width:620px}
  .hero p b{color:var(--ink)}
  .hero-cta{display:flex;gap:14px;margin-top:34px;flex-wrap:wrap}
  @media(max-width:560px){.hero{padding:64px 0 48px}.hero h1{font-size:32px}}

  .pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:30px}
  .pillar{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:22px}
  .pillar .ic{font-size:22px;margin-bottom:12px}
  .pillar h3{font-size:15px;font-weight:600;margin-bottom:8px}
  .pillar p{font-size:13.5px;color:var(--muted)}
  @media(max-width:680px){.pillars{grid-template-columns:1fr}}

  .posts{margin-top:26px;display:flex;flex-direction:column}
  .post{display:flex;gap:20px;padding:22px 0;border-bottom:1px solid var(--line);transition:.18s}
  .post:hover{transform:translateX(4px)}
  .post:hover .post-title{color:var(--accent-ink)}
  .post-date{flex-shrink:0;width:96px;font-size:12.5px;color:var(--faint);padding-top:3px;
    font-variant-numeric:tabular-nums}
  .post-body{flex:1}
  .post-tag{display:inline-block;font-size:11px;font-weight:600;color:var(--accent-ink);
    background:var(--accent-soft);padding:3px 9px;border-radius:6px;margin-bottom:8px}
  .post-title{font-size:18px;font-weight:600;margin-bottom:6px;transition:.18s}
  .post-excerpt{font-size:14px;color:var(--muted)}
  @media(max-width:560px){.post{flex-direction:column;gap:6px}.post-date{width:auto}}

  .build{background:var(--bg2);border:1px solid var(--line);border-radius:16px;padding:30px;margin-top:26px}
  .build-group + .build-group{margin-top:26px;padding-top:26px;border-top:1px solid var(--line)}
  .build-group-label{font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
    color:var(--accent-ink);margin-bottom:16px}
  .build-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
  .chip{display:flex;gap:12px;align-items:flex-start;font-size:14px;color:var(--muted)}
  .chip b{color:var(--ink);font-weight:600}
  .chip .dot{color:var(--accent-ink);margin-top:2px}
  @media(max-width:560px){.build-grid{grid-template-columns:1fr}}

  .contact-box{background:var(--bg2);border:1px solid var(--line);border-radius:16px;
    padding:34px;text-align:center;margin-top:26px}
  .contact-box h2{margin-bottom:10px}
  .contact-box p{color:var(--muted);margin-bottom:22px}
  #contact{border-top:none}
</style>
