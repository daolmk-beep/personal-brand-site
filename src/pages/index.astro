---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// 선별된 글 3편 (draft 제외, 날짜 내림차순)
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;

// 증거바 — 모두 사이트에 이미 명시된 주장 기반. 숫자만 바꾸면 됨.
const stats = [
  { big: '현직 CPA', small: 'M&A 실사 · 감사 · 밸류에이션' },
  { big: '7+', small: '직접 구축한 분석 엔진 · 모듈' },
  { big: '0.000%', small: '골든값(DCF·WACC) 재현 오차' },
  { big: '100%', small: '증거 해시로 추적되는 발견사항' },
];

// 함께 풀 수 있는 일 (기존 Build 섹션을 서비스 카드로 흡수)
const services = [
  {
    label: '재무 · 세무 실사 (FDD)',
    title: '실사를 검증 가능한 파이프라인으로',
    desc: '손으로 하던 실사를 반복·추적 가능한 워크플로로. 증거에서 출발해 보고서 초안까지 일관되게.',
    items: [
      '반복 가능한 실사 분석 워크플로',
      '증거 추적 기반의 발견사항 정리',
      '보고서 초안 자동화',
    ],
  },
  {
    label: '밸류에이션 모델링',
    title: '검증을 거친 가치평가',
    desc: '표준 기법을 골든값으로 검증한 뒤에만 사용합니다. 산출물은 수식까지 살아있는 엑셀로.',
    items: [
      'DCF · Comps 등 표준 기법 모델링',
      '검증된 계산 로직 (골든값 게이팅)',
      '수식이 살아있는 엑셀 산출물',
    ],
  },
  {
    label: '산업분석 · IB',
    title: '컨설팅급 산업분석과 IM',
    desc: '시장·경쟁구도를 구조화해 리서치하고, 설득력 있는 스토리라인으로 덱까지 잇습니다.',
    items: [
      '시장 · 경쟁구도 구조화 리서치',
      'Porter 5 Forces 등 프레임워크 분석',
      'IM · 피치 덱 초안',
    ],
  },
];

// 일하는 방식 (기존 3 pillar)
const principles = [
  { ic: '🧱', h: '증거 우선', p: '결론보다 절차가 먼저. 모든 발견사항은 해시로 봉인된 증거로 역추적됩니다.' },
  { ic: '🎯', h: '골든값 검증', p: 'DCF·WACC를 0.000% 오차로 재현할 때까지 모듈을 승격하지 않습니다.' },
  { ic: '⚖️', h: '책임의 경계', p: 'AI는 초안·요약·플래그까지. 최종 판단과 의견 표명은 사람(CPA)이 합니다.' },
];
---
<Base>
  <!-- HERO -->
  <div class="wrap">
    <section class="hero">
      <span class="eyebrow">현직 CPA · AI 자동화 융합</span>
      <h1>팀이 한 달 걸리던 IM·DD보고서를,<br><b>혼자서 1주일에.</b></h1>
      <p>재무·세무실사부터 밸류에이션, 산업분석·Porter 5 Forces·IM 덱까지 —
         손이 아니라 <b>검증 가능한 파이프라인</b>으로 풉니다.
         증거에서 출발하고, 골든값으로 검증하며, 결론은 사람이 책임집니다.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="#contact">협업·문의하기 →</a>
        <a class="btn btn-ghost" href="#services">무엇을 만드는가</a>
      </div>
    </section>
  </div>

  <!-- PROOF BAR -->
  <div class="wrap-wide">
    <div class="proof">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-big">{s.big}</div>
          <div class="stat-small">{s.small}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- SERVICES -->
  <div class="wrap-wide">
    <section id="services">
      <div class="sec-label">함께 풀 수 있는 일</div>
      <h2>자동화 엔진이 담당하는 세 가지 영역</h2>
      <p class="lead">아래는 실제 업무를 풀기 위해 만든 자동화 엔진들입니다. 모두 셀프테스트로 게이팅되며,
        구체적 딜 정보는 담지 않습니다.</p>

      <div class="svc-grid">
        {services.map((s) => (
          <div class="svc">
            <div class="svc-label">{s.label}</div>
            <h3>{s.title}</h3>
            <p class="svc-desc">{s.desc}</p>
            <ul class="svc-items">
              {s.items.map((it) => <li>{it}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- HOW I WORK -->
  <div class="wrap-wide">
    <section id="how">
      <div class="sec-label">일하는 방식</div>
      <h2>빠른 AI 초안, 그리고 회계사의 책임</h2>
      <div class="principles">
        {principles.map((p) => (
          <div class="principle">
            <div class="ic">{p.ic}</div>
            <h4>{p.h}</h4>
            <p>{p.p}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- WRITING (demoted) -->
  <div class="wrap">
    <section id="writing">
      <div class="sec-label">Writing</div>
      <h2>선별된 글</h2>
      <p class="lead">자동화하며 마주친 문제와 방법론. 구체적 딜 정보는 담지 않습니다.</p>

      <div class="posts">
        {posts.map((post) => (
          <a class="post" href={`${base}blog/${post.slug}`}>
            <div class="post-date">{fmt(post.data.date)}</div>
            <div class="post-body">
              {post.data.tag && <span class="post-tag">{post.data.tag}</span>}
              <div class="post-title">{post.data.title}</div>
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top:22px">
        <a class="btn btn-ghost" href={`${base}blog`}>글 전체 보기 →</a>
      </div>
    </section>
  </div>

  <!-- CONTACT -->
  <div class="wrap-wide">
    <section id="contact">
      <div class="contact-box">
        <div class="sec-label" style="color:var(--accent-ink)">Contact</div>
        <h2>실사·밸류에이션 자동화, 같이 풀어볼까요?</h2>
        <p>협업·자문·프로젝트 문의, 또는 글에 대한 어떤 이야기든 환영합니다.</p>
        <div class="contact-actions">
          <a class="btn btn-primary" href="mailto:daolmk@gmail.com">이메일 보내기 →</a>
          <button class="email-copy" type="button" data-email="daolmk@gmail.com">
            <span class="email-text">daolmk@gmail.com</span>
            <span class="email-hint">복사</span>
          </button>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  /* hero */
  .hero{padding:96px 0 64px;border-top:none}
  .eyebrow{display:inline-block;font-size:12px;font-weight:600;letter-spacing:1.5px;
    text-transform:uppercase;color:var(--accent-ink);background:var(--accent-soft);
    padding:6px 12px;border-radius:999px;margin-bottom:24px}
  .hero h1{font-size:46px;line-height:1.22;font-weight:700;letter-spacing:-.5px;margin-bottom:22px}
  .hero h1 b{color:var(--accent-ink);font-weight:700}
  .hero p{font-size:18px;color:var(--muted);max-width:640px}
  .hero p b{color:var(--ink)}
  .hero-cta{display:flex;gap:14px;margin-top:34px;flex-wrap:wrap}
  @media(max-width:560px){.hero{padding:64px 0 44px}.hero h1{font-size:32px}}

  /* proof bar */
  .proof{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;
    background:var(--line);border:1px solid var(--line);border-radius:16px;overflow:hidden;
    margin:8px 0 4px}
  .stat{background:var(--navy);color:#fff;padding:26px 22px;text-align:center}
  .stat-big{font-size:30px;font-weight:700;letter-spacing:-.5px;color:#fff;
    font-variant-numeric:tabular-nums}
  .stat-small{font-size:12.5px;color:#aab2c4;margin-top:8px;line-height:1.5}
  @media(max-width:680px){.proof{grid-template-columns:repeat(2,1fr)}.stat-big{font-size:24px}}

  /* services */
  .svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:30px}
  .svc{position:relative;background:var(--card);border:1px solid var(--line);border-radius:16px;
    padding:28px 26px 26px;display:flex;flex-direction:column;transition:.18s;overflow:hidden}
  .svc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;
    background:linear-gradient(90deg,var(--accent),var(--accent-ink));opacity:.5;transition:.18s}
  .svc:hover{border-color:var(--accent);transform:translateY(-3px);
    box-shadow:0 14px 32px -18px rgba(138,109,22,.45)}
  .svc:hover::before{opacity:1;height:4px}
  .svc-label{font-size:11.5px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
    color:var(--accent-ink);margin-bottom:12px}
  .svc h3{font-size:17px;font-weight:700;line-height:1.4;margin-bottom:10px;letter-spacing:-.2px}
  .svc-desc{font-size:13.5px;color:var(--muted);margin-bottom:16px}
  .svc-items{list-style:none;display:flex;flex-direction:column;gap:9px;
    border-top:1px solid var(--line);padding-top:16px;margin-top:auto}
  .svc-items li{font-size:13px;color:var(--muted);padding-left:16px;position:relative;line-height:1.5}
  .svc-items li::before{content:'◆';position:absolute;left:0;color:var(--accent-ink);font-size:9px;top:4px}
  @media(max-width:820px){.svc-grid{grid-template-columns:1fr}}

  /* principles */
  .principles{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:26px}
  .principle{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:22px}
  .principle .ic{font-size:22px;margin-bottom:12px}
  .principle h4{font-size:15px;font-weight:600;margin-bottom:8px}
  .principle p{font-size:13.5px;color:var(--muted)}
  @media(max-width:680px){.principles{grid-template-columns:1fr}}

  /* writing (demoted, compact) */
  .posts{margin-top:24px;display:flex;flex-direction:column}
  .post{display:flex;gap:20px;padding:16px 0;border-bottom:1px solid var(--line);transition:.18s}
  .post:hover{transform:translateX(4px)}
  .post:hover .post-title{color:var(--accent-ink)}
  .post-date{flex-shrink:0;width:96px;font-size:12.5px;color:var(--faint);padding-top:2px;
    font-variant-numeric:tabular-nums}
  .post-body{flex:1;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
  .post-tag{display:inline-block;font-size:11px;font-weight:600;color:var(--accent-ink);
    background:var(--accent-soft);padding:3px 9px;border-radius:6px}
  .post-title{font-size:16px;font-weight:600;transition:.18s}
  @media(max-width:560px){.post{flex-direction:column;gap:6px}.post-date{width:auto}}

  /* contact */
  .contact-box{background:var(--navy);color:#fff;border-radius:18px;
    padding:48px 34px;text-align:center;margin-top:4px}
  .contact-box .sec-label{margin-bottom:14px}
  .contact-box h2{color:#fff;margin-bottom:12px}
  .contact-box p{color:#aab2c4;margin-bottom:24px;max-width:520px;margin-left:auto;margin-right:auto}
  .contact-box .btn-primary{background:var(--accent);color:var(--navy)}
  .contact-box .btn-primary:hover{filter:brightness(1.06)}
  .contact-actions{display:flex;gap:12px;justify-content:center;align-items:center;flex-wrap:wrap}
  .email-copy{display:inline-flex;align-items:center;gap:10px;cursor:pointer;
    font:inherit;font-size:14px;font-weight:500;color:#fff;
    background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);
    padding:11px 16px;border-radius:10px;transition:.18s;font-variant-numeric:tabular-nums}
  .email-copy:hover{background:rgba(255,255,255,.14);border-color:rgba(255,255,255,.35)}
  .email-hint{font-size:12px;color:var(--accent);font-weight:600}
  .email-copy.copied .email-hint{color:#7bdc9a}
  #contact{border-top:none}
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.email-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const email = btn.dataset.email ?? '';
      const hint = btn.querySelector('.email-hint');
      try {
        await navigator.clipboard.writeText(email);
      } catch {
        // 클립보드 권한이 없으면 메일 주소를 선택 상태로 노출
        const range = document.createRange();
        const text = btn.querySelector('.email-text');
        if (text) { range.selectNodeContents(text); getSelection()?.removeAllRanges(); getSelection()?.addRange(range); }
      }
      if (hint) {
        const prev = hint.textContent;
        hint.textContent = '복사됨 ✓';
        btn.classList.add('copied');
        setTimeout(() => { hint.textContent = prev; btn.classList.remove('copied'); }, 1600);
      }
    });
  });
</script>
