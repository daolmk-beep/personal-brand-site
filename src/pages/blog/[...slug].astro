---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<Base title={`${post.data.title} — LedgerLab`} description={post.data.excerpt}>
  <div class="wrap">
    <article class="article">
      <a class="back" href={`${base}blog`}>← 글 목록</a>
      <div class="meta">
        {post.data.tag && <span class="post-tag">{post.data.tag}</span>}
        <span class="date">{fmt(post.data.date)}</span>
      </div>
      <h1>{post.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</Base>

<style>
  .article{padding:72px 0 40px;max-width:680px}
  .back{font-size:13px;color:var(--faint)}
  .back:hover{color:var(--accent-ink)}
  .meta{display:flex;align-items:center;gap:12px;margin:28px 0 12px}
  .post-tag{font-size:11px;font-weight:600;color:var(--accent-ink);
    background:var(--accent-soft);padding:3px 9px;border-radius:6px}
  .date{font-size:12.5px;color:var(--faint)}
  .article h1{font-size:34px;line-height:1.3;font-weight:700;letter-spacing:-.4px;margin-bottom:32px}
  @media(max-width:560px){.article h1{font-size:26px}}

  .prose{font-size:16.5px;color:#2b2f38;line-height:1.85}
  .prose :global(h2){font-size:22px;font-weight:700;margin:40px 0 14px;color:var(--ink)}
  .prose :global(h3){font-size:18px;font-weight:600;margin:28px 0 10px;color:var(--ink)}
  .prose :global(p){margin-bottom:18px}
  .prose :global(ul),.prose :global(ol){margin:0 0 18px 22px}
  .prose :global(li){margin-bottom:6px}
  .prose :global(a){color:var(--accent-ink);text-decoration:underline;text-underline-offset:3px}
  .prose :global(blockquote){border-left:3px solid var(--accent);background:var(--accent-soft);
    padding:12px 18px;border-radius:0 8px 8px 0;margin:0 0 18px;color:#5a4a12}
  .prose :global(code){background:#f1f2f4;padding:2px 6px;border-radius:5px;font-size:14px}
  .prose :global(pre){background:#1b1f29;color:#e7e9ee;padding:18px;border-radius:10px;
    overflow-x:auto;margin-bottom:18px}
  .prose :global(pre code){background:none;padding:0}
  .prose :global(hr){border:none;border-top:1px solid var(--line);margin:32px 0}
  .prose :global(strong){color:var(--ink)}
  .prose :global(figure){margin:24px 0}
  .prose :global(figure img){width:100%;height:auto;display:block;border:1px solid var(--line);
    border-radius:10px;box-shadow:0 2px 14px rgba(20,30,50,.08)}
  .prose :global(figcaption){font-size:13px;color:var(--faint);line-height:1.6;
    margin-top:8px;text-align:center}
</style>
